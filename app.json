{
  "expo": {
    "name": "Finance App",
    "slug": "finance-app",
    "version": "1.0.0",
    "scheme": "financeapp",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seuNome.financeapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6366f1"
      },
      "package": "com.seuNome.financeapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "pwa": {
        "enabled": true,
        "name": "Finance App",
        "short_name": "Finance",
        "description": "Controle financeiro pessoal",
        "background_color": "#ffffff",
        "theme_color": "#6366f1",
        "display": "standalone",
        "orientation": "portrait",
        "start_url": "/"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
